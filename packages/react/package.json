{
  "name": "@markoradak/color-picker",
  "version": "0.0.1",
  "description": "A compound-component React color picker and gradient editor",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./presets": {
      "import": {
        "types": "./dist/components/presets.d.ts",
        "default": "./dist/presets.js"
      },
      "require": {
        "types": "./dist/components/presets.d.ts",
        "default": "./dist/presets.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --outDir dist",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "colord": "^2.9.3",
    "@radix-ui/react-popover": "^1.1.6"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "react",
    "color-picker",
    "gradient",
    "color",
    "compound-component",
    "radix",
    "tailwindcss"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/markoradak/color-picker"
  }
}
